# Canonical TianGong CLI environment keys.
# The CLI also supports a few legacy aliases during migration,
# but new code and new docs should use these names.

TIANGONG_API_BASE_URL=
TIANGONG_API_KEY=
TIANGONG_REGION=us-east-1

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4

TIANGONG_KB_BASE_URL=
TIANGONG_KB_API_KEY=

TIANGONG_MINERU_BASE_URL=
TIANGONG_MINERU_API_KEY=
